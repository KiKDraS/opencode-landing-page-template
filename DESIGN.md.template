‚îú‚îÄ‚îÄ layout/
‚îÇ   ‚îú‚îÄ‚îÄ navigation.js      # Mobile menu, sticky header, scroll spy
‚îÇ   ‚îî‚îÄ‚îÄ scroll-reveal.js   # IntersectionObserver reveal animations
‚îú‚îÄ‚îÄ components/
‚îÇ   ‚îú‚îÄ‚îÄ carousel.js        # Self-contained carousel/slider
‚îÇ   ‚îú‚îÄ‚îÄ accordion.js       # Disclosure pattern
‚îÇ   ‚îú‚îÄ‚îÄ dialog.js          # Modal dialog management
‚îÇ   ‚îî‚îÄ‚îÄ [component].js     # One file per component
‚îú‚îÄ‚îÄ utils/
‚îÇ   ‚îú‚îÄ‚îÄ debounce.js        # Pure debounce function
‚îÇ   ‚îú‚îÄ‚îÄ throttle.js        # Pure throttle function
‚îÇ   ‚îú‚îÄ‚îÄ dom.js             # DOM query helpers
‚îÇ   ‚îî‚îÄ‚îÄ [util].js          # Pure, stateless utilities
‚îî‚îÄ‚îÄ main.js                # ENTRY POINT ‚Äî ONLY initialization calls
```

### 5.2 Module Contract (EVERY module in `layout/` and `components/`)
```javascript
// 1. NO side effects on import
// 2. Single exported init function
// 3. Accepts optional config object
// 4. Uses native browser APIs first
// 5. Returns cleanup/destroy function (optional)

export function initComponent(config = {}) {
  const {
    selector = '.component',
  } = config;

  const elements = document.querySelectorAll(selector);
  if (!elements.length) return;

  elements.forEach(element => {
    // Implementation using native APIs
  });

  return () => { /* cleanup listeners */ };
}
```

### 5.3 Entry Point Contract (`src/main.js`)
```javascript
// 1. ONLY imports and calls init functions
// 2. NO logic, NO DOM manipulation, NO event listeners
// 3. Sequential execution, top to bottom
// 4. ES modules are deferred by default ‚Äî NO DOMContentLoaded

import { initNavigation } from './js/layout/navigation.js';
import { initScrollReveal } from './js/layout/scroll-reveal.js';

initNavigation();
initScrollReveal({ threshold: 0.1 });
```

### 5.4 JavaScript Patterns (MANDATORY)
- **ES Modules only** ‚Äî `type="module"` in HTML
- **Async/await** ‚Äî no `.then()` chains
- **Optional chaining** ‚Äî `obj?.prop?.method()`
- **Nullish coalescing** ‚Äî `value ?? default`
- **Array methods** ‚Äî `map`, `filter`, `reduce`, `find` over loops
- **Destructuring** ‚Äî `const { a, b } = obj`
- **Early returns** ‚Äî guard clauses over nesting
- **No classes** ‚Äî factory functions / module pattern preferred
- **No `this` binding issues** ‚Äî arrow functions for callbacks

