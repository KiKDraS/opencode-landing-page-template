{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "*": "ask",
      "git *": "allow",
      "npm *": "allow",
      "pnpm *": "allow",
      "rm *": "deny",
      "grep *": "allow"
    }
  },
  "plugin": ["@dietrichgebert/ponytail"],
  "mcp": {
    "playwright-test": {
      "type": "local",
      "command": ["npx", "playwright", "run-test-mcp-server"],
      "enabled": true
    },
    "codegraph": {
      "type": "local",
      "command": ["npx", "@colbymchenry/codegraph", "serve", "--mcp"],
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{file:.opencode/secrets/context7-api-key}"
      },
      "enabled": false
    }
  },
  "default_agent": "orchestrator",
  "tools": {
    "playwright*": false
  },
  "agent": {
    "orchestrator": {
      "description": "Main orchestrator. Brainstorms, maps architectural blueprints, and executes the sequential development and testing pipeline.",
      "mode": "primary",
      "tools": { "task": true, "read": true }
    },
    "frontend-dev": {
      "description": "Consolidated developer sub-agent. Builds cohesive features writing HTML structures, modular styles, and JS interaction in tandem.",
      "mode": "subagent",
      "tools": { "write": true, "edit": true, "read": true }
    },
    "code-review": {
      "description": "Strict compliance auditor. Verifies generated code against the requested specifications and skills checklists.",
      "mode": "subagent",
      "tools": { "read": true }
    },
    "playwright-test-planner": {
      "description": "Use this agent to create a comprehensive test plan markdown by exploring the web interface.",
      "mode": "subagent",
      "prompt": "{file:.opencode/prompts/playwright-test-planner.md}",
      "tools": {
        "ls": true,
        "glob": true,
        "grep": true,
        "read": true,
        "playwright-test*browser_*": true,
        "playwright-test*planner_*": true
      }
    },
    "playwright-test-generator": {
      "description": "Use this agent to automatically generate real Playwright TypeScript source code files from written test plans.",
      "mode": "subagent",
      "prompt": "{file:.opencode/prompts/playwright-test-generator.md}",
      "tools": {
        "ls": true,
        "glob": true,
        "grep": true,
        "read": true,
        "playwright-test*browser_*": true,
        "playwright-test*generator_*": true
      }
    },
    "playwright-test-healer": {
      "description": "Use this agent to run, debug, and auto-heal/fix failing Playwright tests dynamically.",
      "mode": "subagent",
      "prompt": "{file:.opencode/prompts/playwright-test-healer.md}",
      "tools": {
        "ls": true,
        "glob": true,
        "grep": true,
        "read": true,
        "edit": true,
        "write": true,
        "playwright-test*browser_*": true,
        "playwright-test*test_*": true
      }
    }
  }
}
